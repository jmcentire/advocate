      "output_type": "float",
      "error_cases": [],
      "preconditions": [],
      "postconditions": [
        "Returns non-negative float representing estimated USD cost",
        "Uses fuzzy prefix matching against _PRICING dictionary keys",
        "Falls back to default pricing (3.0 input, 15.0 output per 1M tokens) if no match"
